{
  "compilerOptions": {
    "composite": true,
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "../dist-electron",
    "rootDir": ".."
  },
  "include": ["*.ts", "*.cts", "../domain/**/*.ts", "../infrastructure/**/*.ts", "../support/**/*.ts"]
}
